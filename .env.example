# ─────────────────────────────────────────────────────────────────────────────
# Best Bottles — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Convex (required) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=              # Convex deployment URL (e.g. https://your-project.convex.cloud)
NEXT_PUBLIC_CONVEX_SITE_URL=         # Convex HTTP routes base URL (e.g. https://your-project.convex.site)

# ── Sanity CMS (required for editorial content) ──────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=       # Sanity project ID from sanity.io/manage
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-01

# Sanity Studio overrides (optional — falls back to NEXT_PUBLIC_ vars above)
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=

# ── Shopify (required for checkout & variant sync) ────────────────────────────
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=    # e.g. your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=                 # Shopify Admin API access token (keep secret)
# Verifies X-Shopify-Hmac-Sha256. Use the custom app's "API secret key" (same screen as API key) — NOT the Admin access token (shpat_). See Shopify HTTPS webhook verification docs.
SHOPIFY_WEBHOOK_SECRET=

# ── AI Services (required for Grace AI assistant) ─────────────────────────────
OPENAI_API_KEY=                      # OpenAI API key (voice, realtime, transcription)
ANTHROPIC_API_KEY=                   # Anthropic API key (Claude model for Grace) — set in Convex dashboard env vars

# ── ElevenLabs Voice (required for primary Grace voice provider) ──────────────
ELEVENLABS_API_KEY=                  # ElevenLabs server-side key (TTS + STT proxy)
ELEVENLABS_AGENT_ID=                 # Conversational AI agent ID (e.g. agent_...)
ELEVENLABS_VOICE_ID=                 # Voice ID for ElevenLabs turbo v2.5
ELEVENLABS_WEBHOOK_SECRET=           # Shared secret for ElevenLabs → /api/elevenlabs/* webhook verification
NEXT_PUBLIC_GRACE_VOICE_PROVIDER=elevenlabs  # "elevenlabs" (default) or "text"

# ── Clerk / Portal Auth (optional; leave false until keys are verified) ─────
NEXT_PUBLIC_CLERK_ENABLED=false
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portal
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portal
